<!-- iOS PWA support -->

<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="CodeLearn">
<link rel="apple-touch-icon" href="icons/icon-192.png">

<!-- Android / SEO -->

<meta name="mobile-web-app-capable" content="yes">
<meta name="application-name" content="CodeLearn">
<meta name="description" content="Apprenez Python, JavaScript, Rust et plus avec un tuteur IA interactif.">

<!-- Open Graph -->

<meta property="og:title" content="CodeLearn — Apprenez à coder">
<meta property="og:description" content="Tuteur IA, Bug Hunt, défis de code. Disponible hors-ligne.">
<meta property="og:type" content="website">

<!-- Icons -->

<link rel="icon" type="image/png" sizes="192x192" href="icons/icon-192.png">
<link rel="icon" type="image/png" sizes="512x512" href="icons/icon-512.png">

<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c10;
    --surface: #111318;
    --surface2: #1a1d24;
    --border: #2a2d35;
    --accent: #00ff9d;
    --accent2: #ff6b35;
    --accent3: #7b61ff;
    --text: #e2e8f0;
    --muted: #6b7280;
    --error: #ff4444;
    --success: #00ff9d;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘JetBrains Mono’, monospace;
min-height: 100vh;
overflow-x: hidden;
}

/* Scanlines effect */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background: repeating-linear-gradient(
0deg,
transparent,
transparent 2px,
rgba(0,255,157,0.015) 2px,
rgba(0,255,157,0.015) 4px
);
pointer-events: none;
z-index: 9999;
}

/* Grid background */
.bg-grid {
position: fixed;
inset: 0;
background-image:
linear-gradient(rgba(0,255,157,0.03) 1px, transparent 1px),
linear-gradient(90deg, rgba(0,255,157,0.03) 1px, transparent 1px);
background-size: 40px 40px;
pointer-events: none;
z-index: 0;
}

/* Header */
.header {
position: relative;
z-index: 10;
display: flex;
align-items: center;
justify-content: space-between;
padding: 20px 40px;
border-bottom: 1px solid var(–border);
background: rgba(10,12,16,0.8);
backdrop-filter: blur(12px);
}

.logo {
font-family: ‘Syne’, sans-serif;
font-size: 1.5rem;
font-weight: 800;
color: var(–accent);
text-shadow: 0 0 20px rgba(0,255,157,0.5);
letter-spacing: -1px;
}

.logo span { color: var(–text); }

.header-badge {
font-size: 0.65rem;
background: rgba(0,255,157,0.1);
border: 1px solid rgba(0,255,157,0.3);
color: var(–accent);
padding: 4px 10px;
border-radius: 2px;
letter-spacing: 2px;
text-transform: uppercase;
}

/* Main layout */
.app {
position: relative;
z-index: 1;
display: grid;
grid-template-columns: 280px 1fr;
height: calc(100vh - 65px);
}

/* Sidebar */
.sidebar {
border-right: 1px solid var(–border);
padding: 24px 0;
overflow-y: auto;
background: var(–surface);
}

.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-track { background: transparent; }
.sidebar::-webkit-scrollbar-thumb { background: var(–border); border-radius: 2px; }

.sidebar-section {
padding: 0 20px 20px;
}

.sidebar-label {
font-size: 0.6rem;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 12px;
display: flex;
align-items: center;
gap: 8px;
}

.sidebar-label::after {
content: ‘’;
flex: 1;
height: 1px;
background: var(–border);
}

.lang-btn {
display: flex;
align-items: center;
gap: 12px;
width: 100%;
padding: 12px 16px;
border: 1px solid transparent;
border-radius: 4px;
background: transparent;
color: var(–muted);
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.8rem;
cursor: pointer;
transition: all 0.2s;
margin-bottom: 4px;
text-align: left;
}

.lang-btn:hover {
border-color: var(–border);
color: var(–text);
background: var(–surface2);
}

.lang-btn.active {
border-color: var(–accent);
color: var(–accent);
background: rgba(0,255,157,0.05);
box-shadow: inset 3px 0 0 var(–accent);
}

.lang-icon {
width: 28px;
height: 28px;
border-radius: 4px;
display: flex;
align-items: center;
justify-content: center;
font-size: 0.7rem;
font-weight: 700;
flex-shrink: 0;
}

.lang-meta {
flex: 1;
}

.lang-name { display: block; font-weight: 600; }

.lang-level {
font-size: 0.65rem;
color: var(–muted);
margin-top: 2px;
}

.progress-bar {
height: 2px;
background: var(–border);
border-radius: 1px;
margin-top: 4px;
overflow: hidden;
}

.progress-fill {
height: 100%;
border-radius: 1px;
transition: width 0.5s ease;
}

/* Main content */
.main {
display: grid;
grid-template-rows: auto 1fr auto;
overflow: hidden;
}

/* Tabs */
.tabs {
display: flex;
border-bottom: 1px solid var(–border);
background: var(–surface);
padding: 0 24px;
}

.tab {
padding: 14px 20px;
font-size: 0.75rem;
color: var(–muted);
cursor: pointer;
border-bottom: 2px solid transparent;
transition: all 0.2s;
letter-spacing: 1px;
text-transform: uppercase;
white-space: nowrap;
}

.tab:hover { color: var(–text); }

.tab.active {
color: var(–accent);
border-bottom-color: var(–accent);
}

/* Content panels */
.panel {
display: none;
overflow: hidden;
}
.panel.active { display: grid; }

/* Lesson panel */
#panel-lesson {
grid-template-columns: 1fr 1fr;
height: 100%;
}

.lesson-text {
padding: 28px;
overflow-y: auto;
border-right: 1px solid var(–border);
}

.lesson-text::-webkit-scrollbar { width: 4px; }
.lesson-text::-webkit-scrollbar-track { background: transparent; }
.lesson-text::-webkit-scrollbar-thumb { background: var(–border); border-radius: 2px; }

.lesson-title {
font-family: ‘Syne’, sans-serif;
font-size: 1.4rem;
font-weight: 800;
color: var(–text);
margin-bottom: 6px;
line-height: 1.2;
}

.lesson-subtitle {
font-size: 0.7rem;
color: var(–accent);
letter-spacing: 2px;
text-transform: uppercase;
margin-bottom: 20px;
}

.lesson-body {
font-size: 0.8rem;
line-height: 1.8;
color: #94a3b8;
}

.lesson-body p { margin-bottom: 14px; }

.inline-code {
background: var(–surface2);
border: 1px solid var(–border);
padding: 2px 6px;
border-radius: 3px;
color: var(–accent);
font-size: 0.75rem;
}

.concept-block {
background: var(–surface2);
border: 1px solid var(–border);
border-left: 3px solid var(–accent3);
padding: 14px 16px;
border-radius: 4px;
margin: 16px 0;
font-size: 0.75rem;
line-height: 1.7;
}

.concept-block .concept-title {
font-weight: 700;
color: var(–accent3);
margin-bottom: 6px;
font-size: 0.7rem;
letter-spacing: 1px;
text-transform: uppercase;
}

/* Code editor side */
.code-side {
display: grid;
grid-template-rows: auto 1fr auto;
background: #0d0f14;
}

.editor-header {
display: flex;
align-items: center;
justify-content: space-between;
padding: 10px 16px;
border-bottom: 1px solid var(–border);
background: var(–surface);
}

.editor-filename {
font-size: 0.7rem;
color: var(–muted);
display: flex;
align-items: center;
gap: 8px;
}

.dot { width: 8px; height: 8px; border-radius: 50%; }
.dot-red { background: #ff5f57; }
.dot-yellow { background: #febc2e; }
.dot-green { background: #28c840; }

.run-btn {
display: flex;
align-items: center;
gap: 6px;
padding: 6px 14px;
background: var(–accent);
color: #000;
border: none;
border-radius: 3px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.7rem;
font-weight: 700;
cursor: pointer;
transition: all 0.2s;
text-transform: uppercase;
letter-spacing: 1px;
}

.run-btn:hover {
background: #00e68a;
box-shadow: 0 0 20px rgba(0,255,157,0.4);
}

.run-btn:disabled {
opacity: 0.5;
cursor: not-allowed;
}

.code-editor {
padding: 16px;
overflow: hidden;
}

textarea {
width: 100%;
height: 100%;
background: transparent;
border: none;
outline: none;
color: var(–text);
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.8rem;
line-height: 1.6;
resize: none;
tab-size: 2;
}

.output-panel {
border-top: 1px solid var(–border);
padding: 12px 16px;
min-height: 80px;
max-height: 120px;
background: #080a0d;
overflow-y: auto;
}

.output-label {
font-size: 0.6rem;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 8px;
}

.output-text {
font-size: 0.75rem;
line-height: 1.5;
white-space: pre-wrap;
}

.output-text.success { color: var(–success); }
.output-text.error { color: var(–error); }
.output-text.thinking { color: var(–accent3); }

/* Challenge panel */
#panel-challenge {
grid-template-columns: 1fr;
grid-template-rows: 1fr;
}

.challenge-container {
display: grid;
grid-template-columns: 1fr 1fr;
height: 100%;
overflow: hidden;
}

.challenge-left {
padding: 28px;
border-right: 1px solid var(–border);
overflow-y: auto;
}

.challenge-badge {
display: inline-flex;
align-items: center;
gap: 6px;
font-size: 0.6rem;
letter-spacing: 2px;
text-transform: uppercase;
padding: 4px 10px;
border-radius: 2px;
margin-bottom: 16px;
}

.badge-easy { background: rgba(0,255,157,0.1); color: var(–accent); border: 1px solid rgba(0,255,157,0.3); }
.badge-medium { background: rgba(255,107,53,0.1); color: var(–accent2); border: 1px solid rgba(255,107,53,0.3); }
.badge-hard { background: rgba(123,97,255,0.1); color: var(–accent3); border: 1px solid rgba(123,97,255,0.3); }

.challenge-title {
font-family: ‘Syne’, sans-serif;
font-size: 1.3rem;
font-weight: 800;
margin-bottom: 12px;
line-height: 1.2;
}

.challenge-desc {
font-size: 0.78rem;
line-height: 1.8;
color: #94a3b8;
margin-bottom: 20px;
}

.test-cases {
display: flex;
flex-direction: column;
gap: 8px;
}

.test-case {
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 4px;
padding: 10px 14px;
font-size: 0.72rem;
display: flex;
justify-content: space-between;
align-items: center;
transition: border-color 0.3s;
}

.test-case.pass { border-color: var(–success); }
.test-case.fail { border-color: var(–error); }

.test-io { color: var(–muted); }
.test-io span { color: var(–text); }
.test-status { font-size: 0.65rem; letter-spacing: 1px; }
.test-status.pass { color: var(–success); }
.test-status.fail { color: var(–error); }

.challenge-right {
display: grid;
grid-template-rows: auto 1fr auto;
background: #0d0f14;
}

/* AI Chat panel */
#panel-ai {
grid-template-columns: 1fr;
grid-template-rows: 1fr auto;
}

.chat-messages {
padding: 24px;
overflow-y: auto;
display: flex;
flex-direction: column;
gap: 20px;
}

.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-track { background: transparent; }
.chat-messages::-webkit-scrollbar-thumb { background: var(–border); border-radius: 2px; }

.msg {
display: flex;
gap: 14px;
animation: fadeUp 0.3s ease;
}

@keyframes fadeUp {
from { opacity: 0; transform: translateY(10px); }
to { opacity: 1; transform: translateY(0); }
}

.msg-avatar {
width: 32px;
height: 32px;
border-radius: 4px;
display: flex;
align-items: center;
justify-content: center;
font-size: 0.65rem;
font-weight: 700;
flex-shrink: 0;
margin-top: 2px;
}

.msg-avatar.ai { background: rgba(0,255,157,0.15); color: var(–accent); border: 1px solid rgba(0,255,157,0.3); }
.msg-avatar.user { background: rgba(123,97,255,0.15); color: var(–accent3); border: 1px solid rgba(123,97,255,0.3); }

.msg-content {
flex: 1;
}

.msg-author {
font-size: 0.65rem;
letter-spacing: 1px;
text-transform: uppercase;
margin-bottom: 6px;
}

.msg-author.ai { color: var(–accent); }
.msg-author.user { color: var(–accent3); }

.msg-text {
font-size: 0.78rem;
line-height: 1.8;
color: #94a3b8;
}

.msg-text code {
background: var(–surface2);
border: 1px solid var(–border);
padding: 2px 6px;
border-radius: 3px;
color: var(–accent);
font-size: 0.72rem;
}

.msg-text pre {
background: var(–surface2);
border: 1px solid var(–border);
padding: 12px 14px;
border-radius: 4px;
margin: 10px 0;
font-size: 0.72rem;
overflow-x: auto;
color: var(–text);
line-height: 1.6;
}

.chat-input-area {
border-top: 1px solid var(–border);
padding: 20px 24px;
display: flex;
gap: 12px;
align-items: flex-end;
background: var(–surface);
}

.chat-input {
flex: 1;
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 4px;
padding: 12px 16px;
color: var(–text);
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.8rem;
resize: none;
min-height: 44px;
max-height: 120px;
outline: none;
transition: border-color 0.2s;
line-height: 1.5;
}

.chat-input:focus { border-color: var(–accent3); }

.send-btn {
padding: 12px 20px;
background: var(–accent3);
color: #fff;
border: none;
border-radius: 4px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.7rem;
font-weight: 700;
cursor: pointer;
transition: all 0.2s;
text-transform: uppercase;
letter-spacing: 1px;
white-space: nowrap;
}

.send-btn:hover { background: #9580ff; box-shadow: 0 0 20px rgba(123,97,255,0.4); }
.send-btn:disabled { opacity: 0.5; cursor: not-allowed; }

/* Bottom status bar */
.statusbar {
border-top: 1px solid var(–border);
padding: 6px 24px;
background: var(–surface);
display: flex;
align-items: center;
justify-content: space-between;
font-size: 0.62rem;
color: var(–muted);
letter-spacing: 1px;
z-index: 10;
}

.status-left, .status-right {
display: flex;
align-items: center;
gap: 20px;
}

.status-item {
display: flex;
align-items: center;
gap: 6px;
}

.status-dot {
width: 6px;
height: 6px;
border-radius: 50%;
background: var(–accent);
box-shadow: 0 0 6px var(–accent);
animation: pulse 2s infinite;
}

@keyframes pulse {
0%, 100% { opacity: 1; }
50% { opacity: 0.4; }
}

/* Typing cursor */
.cursor {
display: inline-block;
width: 8px;
height: 14px;
background: var(–accent);
animation: blink 1s step-end infinite;
vertical-align: middle;
margin-left: 2px;
}

@keyframes blink {
0%, 100% { opacity: 1; }
50% { opacity: 0; }
}

/* Scrollbar global */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(–border); border-radius: 2px; }

/* Loading dots */
.loading-dots span {
animation: loadDot 1.4s infinite;
opacity: 0;
}
.loading-dots span:nth-child(2) { animation-delay: 0.2s; }
.loading-dots span:nth-child(3) { animation-delay: 0.4s; }

@keyframes loadDot {
0%, 80%, 100% { opacity: 0; }
40% { opacity: 1; }
}

/* Xp badge */
.xp-badge {
display: inline-flex;
align-items: center;
gap: 4px;
font-size: 0.65rem;
color: var(–accent2);
background: rgba(255,107,53,0.1);
border: 1px solid rgba(255,107,53,0.3);
padding: 3px 8px;
border-radius: 2px;
}

/* Challenge new btn */
.new-challenge-btn {
display: flex;
align-items: center;
gap: 6px;
padding: 8px 14px;
background: transparent;
color: var(–accent2);
border: 1px solid rgba(255,107,53,0.4);
border-radius: 3px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.7rem;
cursor: pointer;
transition: all 0.2s;
letter-spacing: 1px;
}

.new-challenge-btn:hover {
background: rgba(255,107,53,0.1);
border-color: var(–accent2);
}

.hint-btn {
display: flex;
align-items: center;
gap: 6px;
padding: 8px 14px;
background: transparent;
color: var(–accent3);
border: 1px solid rgba(123,97,255,0.4);
border-radius: 3px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.7rem;
cursor: pointer;
transition: all 0.2s;
letter-spacing: 1px;
}

.hint-btn:hover {
background: rgba(123,97,255,0.1);
border-color: var(–accent3);
}

.editor-actions {
display: flex;
gap: 8px;
align-items: center;
}

/* ===== BUG HUNT ===== */
#panel-bughunt {
grid-template-columns: 1fr;
grid-template-rows: 1fr;
}

.bughunt-container {
display: grid;
grid-template-columns: 380px 1fr;
height: 100%;
overflow: hidden;
}

.bughunt-left {
padding: 24px;
border-right: 1px solid var(–border);
overflow-y: auto;
display: flex;
flex-direction: column;
gap: 16px;
}

.bughunt-header {
display: flex;
align-items: center;
gap: 10px;
}

.bug-icon {
width: 36px;
height: 36px;
background: rgba(255,68,68,0.1);
border: 1px solid rgba(255,68,68,0.35);
border-radius: 6px;
display: flex;
align-items: center;
justify-content: center;
font-size: 1.1rem;
flex-shrink: 0;
}

.bughunt-title {
font-family: ‘Syne’, sans-serif;
font-size: 1.1rem;
font-weight: 800;
color: var(–text);
}

.bughunt-subtitle {
font-size: 0.65rem;
color: var(–muted);
letter-spacing: 1px;
text-transform: uppercase;
margin-top: 2px;
}

.bug-desc {
font-size: 0.77rem;
line-height: 1.8;
color: #94a3b8;
}

.bugs-found {
display: flex;
flex-direction: column;
gap: 8px;
}

.bug-item {
display: flex;
align-items: flex-start;
gap: 10px;
padding: 10px 12px;
border-radius: 4px;
border: 1px solid var(–border);
background: var(–surface2);
font-size: 0.72rem;
line-height: 1.6;
color: #94a3b8;
transition: all 0.3s;
cursor: default;
}

.bug-item.found {
border-color: rgba(0,255,157,0.4);
background: rgba(0,255,157,0.05);
color: var(–text);
}

.bug-item.missed {
border-color: rgba(255,68,68,0.3);
background: rgba(255,68,68,0.04);
}

.bug-num {
width: 20px;
height: 20px;
border-radius: 3px;
background: var(–border);
display: flex;
align-items: center;
justify-content: center;
font-size: 0.6rem;
font-weight: 700;
flex-shrink: 0;
margin-top: 1px;
transition: all 0.3s;
}

.bug-item.found .bug-num {
background: var(–accent);
color: #000;
}

.bug-item.missed .bug-num {
background: var(–error);
color: #fff;
}

.timer-bar-wrap {
height: 4px;
background: var(–border);
border-radius: 2px;
overflow: hidden;
}

.timer-bar {
height: 100%;
background: var(–accent2);
border-radius: 2px;
transition: width 1s linear, background 0.5s;
}

.timer-label {
font-size: 0.65rem;
color: var(–muted);
letter-spacing: 1px;
display: flex;
justify-content: space-between;
margin-bottom: 4px;
}

.bughunt-actions {
display: flex;
gap: 8px;
flex-wrap: wrap;
margin-top: 4px;
}

.bughunt-right {
display: grid;
grid-template-rows: auto 1fr auto;
background: #0d0f14;
position: relative;
}

.buggy-line {
background: rgba(255,68,68,0.08) !important;
border-left: 3px solid var(–error) !important;
cursor: pointer;
transition: background 0.2s;
}

.buggy-line:hover {
background: rgba(255,68,68,0.15) !important;
}

.buggy-line.highlighted {
background: rgba(255,68,68,0.2) !important;
animation: flashBug 0.5s ease;
}

@keyframes flashBug {
0%, 100% { background: rgba(255,68,68,0.2); }
50% { background: rgba(255,68,68,0.4); }
}

.score-popup {
position: fixed;
font-family: ‘Syne’, sans-serif;
font-size: 1.4rem;
font-weight: 800;
color: var(–accent);
text-shadow: 0 0 20px rgba(0,255,157,0.6);
pointer-events: none;
z-index: 9998;
animation: scoreFloat 1.2s ease forwards;
}

