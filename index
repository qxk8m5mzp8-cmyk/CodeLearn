const chatHistory = [
  { role: "assistant", content: "Bonjour ! Je suis votre tuteur IA spécialisé en programmation. Je peux vous expliquer des concepts, corriger votre code, vous proposer des exercices adaptés à votre niveau, ou répondre à toutes vos questions sur Python, JavaScript, Rust, SQL ou TypeScript.\n\nQue souhaitez-vous apprendre aujourd'hui ? 🚀" }
