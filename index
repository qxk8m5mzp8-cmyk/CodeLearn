<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>CodeLearn — Apprenez à coder</title>

<!-- PWA Manifest -->

<link rel="manifest" href="manifest.json">

<!-- Theme & Status bar -->

<meta name="theme-color" content="#00ff9d">
<meta name="msapplication-navbutton-color" content="#00ff9d">
