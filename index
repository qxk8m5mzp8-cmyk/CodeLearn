// Hide extra items
for (let i = bhState.bugs.length; i < 3; i++) {
  const el = document.getElementById('bug-item-' + i);
  if (el) el.style.display = 'none';
}

startTimer();
```

} catch(e) {
document.getElementById(‘bh-output’).textContent = ‘Erreur de génération. Réessayez.’;
document.getElementById(‘bh-output’).style.color = ‘var(–error)’;
}

btn.textContent = ‘↻ Nouveau Bug Hunt’;
btn.disabled = false;
}

function escapeHtml(s) {
return s.replace(/&/g,’&’).replace(/</g,’<’).replace(/>/g,’>’);
}

function startTimer() {
if (bhState.timer) clearInterval(bhState.timer);
const total = 180;
bhState.remaining = total;
updateTimerDisplay();
bhState.timer = setInterval(() => {
bhState.remaining–;
updateTimerDisplay();
if (bhState.remaining <= 0) {
clearInterval(bhState.timer);
bhState.active = false;
revealAllBugs();
}
}, 1000);
}

function updateTimerDisplay() {
const m = Math.floor(bhState.remaining / 60).toString().padStart(2, ‘0’);
const s = (bhState.remaining % 60).toString().padStart(2, ‘0’);
document.getElementById(‘timer-text’).textContent = m + ‘:’ + s;
const pct = (bhState.remaining / 180) * 100;
const bar = document.getElementById(‘timer-bar’);
bar.style.width = pct + ‘%’;
bar.style.background = pct > 50 ? ‘var(–accent2)’ : pct > 25 ? ‘#ffaa00’ : ‘var(–error)’;
document.getElementById(‘timer-text’).style.color = pct > 25 ? ‘var(–accent2)’ : ‘var(–error)’;
}

function clickLine(idx) {
if (!bhState.active) return;
const bugIndex = bhState.bugs.findIndex(b => b.line_index === idx);
const lineEl = document.querySelector(`.bh-line[data-idx="${idx}"]`);

if (bugIndex !== -1 && !bhState.found.includes(bugIndex)) {
// Correct!
bhState.found.push(bugIndex);
if (lineEl) { lineEl.style.background = ‘rgba(0,255,157,0.08)’; lineEl.style.borderLeftColor = ‘var(–accent)’; lineEl.style.cursor = ‘default’; }
const bug = bhState.bugs[bugIndex];
const el = document.getElementById(‘bug-item-’ + bugIndex);
if (el) {
el.className = ‘bug-item found’;
el.innerHTML = `<div class="bug-num">${bugIndex+1}</div><div><strong style="color:var(--accent)">Ligne ${bug.line_index+1} :</strong> ${bug.description}</div>`;
}
const xpGain = Math.max(10, Math.round(bhState.remaining / 4));
gainXP(xpGain);
showScorePopup(’+’ + xpGain + ’ XP’, lineEl);
bugsFoundTotal++;
document.getElementById(‘stat-bugs’).textContent = bugsFoundTotal;

```
if (bhState.found.length === bhState.bugs.length) {
  clearInterval(bhState.timer);
  bhState.active = false;
  const bonus = bhState.remaining * 2;
  gainXP(bonus);
  document.getElementById('bh-output').textContent = '🎉 Tous les bugs trouvés ! Bonus temps : +' + bonus + ' XP';
  document.getElementById('bh-output').style.color = 'var(--success)';
  showToast('🐛 Bug Hunt terminé !', 'Tous les bugs trouvés. +' + bonus + ' XP bonus !');
}
```

} else if (bugIndex === -1) {
// Wrong line - flash red
if (lineEl) {
lineEl.style.background = ‘rgba(255,68,68,0.1)’;
lineEl.style.borderLeftColor = ‘var(–error)’;
setTimeout(() => { lineEl.style.background = ‘transparent’; lineEl.style.borderLeftColor = ‘transparent’; }, 600);
}
}
}

function revealAllBugs() {
const out = document.getElementById(‘bh-output’);
out.style.color = ‘var(–error)’;
out.textContent = ‘⏱ Temps écoulé ! ’ + bhState.found.length + ‘/’ + bhState.bugs.length + ’ bugs trouvés.’;
bhState.bugs.forEach((bug, i) => {
if (!bhState.found.includes(i)) {
const el = document.getElementById(‘bug-item-’ + i);
if (el) {
el.className = ‘bug-item missed’;
el.innerHTML = `<div class="bug-num">${i+1}</div><div><strong style="color:var(--error)">Ligne ${bug.line_index+1} :</strong> ${bug.description}</div>`;
}
const lineEl = document.querySelector(`.bh-line[data-idx="${bug.line_index}"]`);
if (lineEl) { lineEl.style.background = ‘rgba(255,68,68,0.08)’; lineEl.style.borderLeftColor = ‘var(–error)’; }
}
});
}

async function getBugHint() {
if (!bhState.active || bhState.bugs.length === 0) return;
const hintArea = document.getElementById(‘bh-hint-area’);
const btn = document.getElementById(‘bh-hint-btn’);
btn.textContent = ‘⏳ Chargement…’;
