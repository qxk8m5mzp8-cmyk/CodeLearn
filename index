// ===== XP & BADGES =====
function gainXP(amount) {
totalXP = Math.max(0, totalXP + amount);
document.getElementById(‘stat-xp’).textContent = totalXP;
// Update header badge
document.querySelector(’.xp-badge’).textContent = ‘⚡ ’ + totalXP + ’ XP’;
// Update XP bar (max level 500 for demo)
const pct = Math.min(100, Math.round((totalXP % 500) / 500 * 100));
const fill = document.getElementById(‘xp-fill’);
if (fill) fill.style.width = pct + ‘%’;
// Check badge unlock
if (totalXP >= 500 && !unlockedBadges.includes(‘level9’)) {
