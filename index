}

let unlockedBadges = [‘streak5’, ‘firstbug’, ‘speedcoder’, ‘python50’];

function showScorePopup(text, anchorEl) {
const popup = document.createElement(‘div’);
popup.className = ‘score-popup’;
popup.textContent = text;
const rect = anchorEl ? anchorEl.getBoundingClientRect() : { left: window.innerWidth/2, top: window.innerHeight/2 };
popup.style.left = (rect.left + 40) + ‘px’;
popup.style.top = (rect.top - 10) + ‘px’;
document.body.appendChild(popup);
setTimeout(() => popup.remove(), 1200);
}

function showToast(title, body) {
const toast = document.createElement(‘div’);
toast.className = ‘toast’;
toast.innerHTML = `<div class="toast-icon">🎖️</div><div><div class="toast-title">${title}</div><div class="toast-body">${body}</div></div>`;
document.body.appendChild(toast);
setTimeout(() => {
toast.classList.add(‘out’);
setTimeout(() => toast.remove(), 300);
}, 3500);
}

