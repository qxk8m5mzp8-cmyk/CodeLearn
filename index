async function runChallenge() {
  const code = document.getElementById('challenge-editor').value;
  const out = document.getElementById('challenge-output');
  out.className = 'output-text thinking';
  out.innerHTML = 'Évaluation en cours <span class="loading-dots"><span>.</span><span>.</span><span>.</span></span>';

  const tests = [
    { input: '"hello"', expected: '"olleh"' },
    { input: '"Python"', expected: '"nohtyP"' },
    { input: '""', expected: '""' }
  ];

  const result = await callClaude(
    `Voici une solution à un défi de programmation (inverser une chaîne sans slicing):\n\`\`\`python\n${code}\n\`\`\`\nÉvalue si cette solution passe ces tests: ${JSON.stringify(tests)}.\nRéponds UNIQUEMENT en JSON avec ce format: {"results": [true/false, true/false, true/false], "feedback": "message court en français"}`,
    `Tu es un évaluateur de code. Réponds UNIQUEMENT en JSON valide, rien d'autre.`
  );

  try {
    const clean = result.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(clean);
    const results = parsed.results || [false, false, false];
    results.forEach((pass, i) => {
      const el = document.getElementById('test-' + i);
      const statusEl = el.querySelector('.test-status');
      el.className = 'test-case ' + (pass ? 'pass' : 'fail');
      statusEl.className = 'test-status ' + (pass ? 'pass' : 'fail');
      statusEl.textContent = pass ? '✓ RÉUSSI' : '✗ ÉCHOUÉ';
    });
    const allPass = results.every(r => r);
    out.className = 'output-text ' + (allPass ? 'success' : 'error');
    out.textContent = (allPass ? '✓ Tous les tests passent ! ' : '✗ Certains tests échouent. ') + (parsed.feedback || '');
  } catch {
    out.className = 'output-text error';
    out.textContent = result;
  }
}

