const hint = await callClaude(
`Dans un code buggué, il reste ${remaining.length} bug(s) non trouvé(s). Donne un indice VAGUE (sans dire la ligne exacte) pour aider l'étudiant. Maximum 2 phrases en français.`,
`Tu es un tuteur bienveillant pour l'apprentissage du code. Sois cryptique mais utile.`
);
