bhState.bugs = data.bugs || [];
bhState.found = [];
bhState.remaining = 180;
bhState.active = true;

```
document.getElementById('bh-title').textContent = data.title || 'Trouver les bugs';
document.getElementById('bh-subtitle').textContent = lang + ' · ' + bhState.bugs.length + ' bugs cachés';
